<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>Gilbert Desktop</string>
    <key>CFBundleExecutable</key>
    <string>GilbertDesktop</string>
    <key>CFBundleIconFile</key>
    <string>icon.icns</string>
    <key>CFBundleIdentifier</key>
    <string>com.gilbert.desktop</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Gilbert Desktop</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>0.1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>13.0</string>
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Permission Descriptions - Required for macOS privacy prompts -->

    <!-- Microphone Access - Required for recording meeting audio -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Gilbert Desktop needs microphone access to record your voice during meetings.</string>

    <!-- Screen Recording - Required for ScreenCaptureKit system audio -->
    <key>NSScreenCaptureUsageDescription</key>
    <string>Gilbert Desktop needs Screen Recording permission to capture system audio from video conferencing apps (Zoom, Meet, Teams, etc.). No video is captured, only audio.</string>

    <!-- Audio Input - Alternative description -->
    <key>NSAudioCaptureUsageDescription</key>
    <string>Gilbert Desktop needs audio access to record meeting audio.</string>

    <!-- App Transport Security - Allow HTTPS connections -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
        <key>NSAllowsArbitraryLoadsForMedia</key>
        <false/>
    </dict>

    <!-- Required for background audio processing -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>
</dict>
</plist>
