{
  "build": {
    "withGlobalTauri": true,
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "cd ../frontend && npm run build",
    "devPath": "http://localhost:5173",
    "distDir": "../../frontend/dist"
  },
  "package": {
    "productName": "Gilbert",
    "version": "0.2.0"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "identifier": "com.gilbert.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "targets": "all",
      "macOS": {
        "entitlements": "entitlements.mac.plist",
        "minimumSystemVersion": "10.15"
      }
    },
    "windows": [
      {
        "title": "Gilbert",
        "width": 1200,
        "height": 850,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "url": "index.html"
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://gilbert-assistant.ovh https://api.gilbert-assistant.ovh wss: ws:; media-src 'self' blob:;"
    },
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "notification": {
        "all": true
      },
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "readFile": true,
        "writeFile": true,
        "readDir": true,
        "copyFile": true,
        "createDir": true,
        "removeDir": true,
        "removeFile": true,
        "renameFile": true,
        "scope": ["$APP/*", "$RESOURCE/*", "$TEMP/*"]
      },
      "path": {
        "all": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://gilbert-assistant.ovh/*", "https://api.gilbert-assistant.ovh/*"]
      },
      "protocol": {
        "all": true,
        "asset": true,
        "assetScope": ["$APP/*", "$RESOURCE/*"]
      }
    },
    "systemTray": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false
    }
  }
}
